# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to source control.

# Supabase project URL (safe to expose to the browser)
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co

# Supabase public anon key (safe to expose to the browser)
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# SECURITY: The service role key grants full database access and bypasses Row Level
# Security. It must NEVER be stored in a VITE_* variable or in this file.
# Store it server-side only (e.g., in a backend .env or a secrets manager) and
# access it exclusively through server/admin endpoints — never in the browser.
#
# Server-side example (backend/.env, NOT committed):
# SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
